# Copy this file to `.env.local` (gitignored) before running `npm run dev`
# or `npm run build`. Vite injects every `VITE_*` variable into
# `import.meta.env` at build time.
#
# The registry must live on the same chain selected by VITE_NETWORK. The default
# app/deployer target is `paseo-next-v2`; do not reuse a registry deployed on
# regular Paseo Asset Hub.
#
# `contracts/scripts/deploy-registry.ts` writes these values
# into `.env.local` after a successful pallet-revive deployment.
VITE_NETWORK=paseo-next-v2
VITE_DOTNS_PRODUCT_DOMAIN=w3spayadmin.dot
VITE_W3SPAY_REGISTRY_ADDRESS=0x70f6a449d770931419cfa8d8412e3a5d6377e905

# Reports surface. Set to empty to disable Reports for a deployment.
VITE_T3RMINAL_BULLETIN_INDEX_ADDRESS=0x3331A87C2B9312E246E6A7eE8D0C0AdD8d282B6F

# Token shown in Balances and merchant detail. Defaults are the pilot CASH asset.
# VITE_TOKEN_SYMBOL=CASH
# VITE_TOKEN_ASSET_ID=50000413
# VITE_TOKEN_PARACHAIN_ID=1500
# VITE_TOKEN_PALLET_INSTANCE=50

# ─── Telemetry ──────────────────────────────────────────────────────
#
# Sentry-backed productivity telemetry —
VITE_W3SPAY_ADMIN_SENTRY_DSN=

# Set to true to upload source maps to Sentry during build (release engineering only).
VITE_W3SPAY_SENTRY_ENABLED=false

# Sentry environment label. Defaults to the Vite build mode.
VITE_W3SPAY_ADMIN_SENTRY_ENV=development
# Traces sample rate (0..1). Defaults to 1.0 — every chain-write
# journey ships a span. Lower this for high-volume admin sessions.
VITE_W3SPAY_ADMIN_SENTRY_TRACES_SAMPLE_RATE=1.0

MNEMONIC=
# DOTNS_MNEMONIC=