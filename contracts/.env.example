# Copy to .env and keep it out of git.
# This sr25519 mnemonic deploys through pallet-revive instantiate_with_code.
DEPLOYER_SEED=

# Optional. Defaults to paseo-next-v2; valid values are defined in ../src/host/networks.ts.
# NETWORK=paseo-next-v2

# Optional for networks with runtime-supplied genesis hashes, e.g. previewnet.
# VITE_CHAIN_GENESIS_HASH=0x...
